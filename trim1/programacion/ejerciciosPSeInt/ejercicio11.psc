Algoritmo ejercicio11
	//jeronimo medina
	//11. Hacer un algoritmo que lea dos números enteros A y B y muestre su diferencia.
	//DEFINICION
	Definir numeroA Como Real;
	Definir numeroB Como Real;
	Definir resultado Como Real;
	//INICIO
	Escribir "digite el numero A y el numero B: ";
	LEER numeroA,numeroB;
	//proceso
	resultado <- numeroA - numeroB;
	//FinAlgoritmo
	Escribir " la diferencia entre el numero a y el numero b es: ", resultado;
	
	
FinAlgoritmo
