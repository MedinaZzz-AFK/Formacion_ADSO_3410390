Algoritmo ejercicio2
	// JERONIMO MEDINA
	//2. Hacer un algoritmo que lea dos números enteros A y B y muestre el doble de su suma.
	//definicion de variables
	Definir numeroA Como entero;
	Definir numeroB Como entero;
	Definir suma Como Entero;
	// inicio
	Escribir "digite el valor de A y B, TENGA EN CUENTA QUE DEBEN SER ENTEROS";
	Leer numeroA, numeroB;
	//Proceso 
	suma <- (numeroA + numeroB)*2;
	//FinAlgoritmo
	escribir "el doble de la suma de sus numeros es: ",suma;
	
FinAlgoritmo
