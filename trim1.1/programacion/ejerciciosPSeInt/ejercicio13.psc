Algoritmo ejercicio13
	//jeronimo medina
	//13. Pedir el radio de un cÌrculo y calcular su ·rea. A=PI*r^2
	//Definir 
	definir radio como real;
	definir area como real;
	definir circulo como cadena;
	definir pi_valor Como Real
	//inicio
	pi_valor <- 3.1416;
	
	Escribir " digite el radio de el circulo para calcular su area: "
	leer radio;
	//Proceso
	area <- pi_valor * (radio^2);
	//FinAlgoritmo
	Escribir " el area de el circulo es: ", area;
	
	
FinAlgoritmo
