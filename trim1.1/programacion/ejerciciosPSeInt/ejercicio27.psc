Algoritmo ejercicio27
	//jeronimo medina
	//27. Pedir un nºmero y decir si es par o impar
	//definicion
	Definir num Como entero;
	//inicio
	Escribir "porfavor digite el numero";
	leer num;
	//Proceso 
	
	si num MOD 2==0 Entonces
		Escribir "el numero es par"
	SiNo
		Escribir "el numero es impar"
	FinSi
	
FinAlgoritmo
