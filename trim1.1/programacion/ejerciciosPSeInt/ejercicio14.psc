Algoritmo ejercicio14
	//jeronimo medina
	//14. Pedir el radio de una circunferencia y calcular su longitud.
	//Definir 
	definir radio Como Real;
	definir longitud_c Como Real;
	definir circunferencia como cadena;
	definir v_pi como real;
	
	//inicio
	v_pi <- 3.1416;
	
	Escribir "digite el radio de el circulo: "
	leer radio;
	//Proceso 
	longitud_c <- 2*v_pi*radio;
	//FinAlgoritmo
	Escribir " la longitud de la circunferencia es: ", longitud_c;
	
FinAlgoritmo
