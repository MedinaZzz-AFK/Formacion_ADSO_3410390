Algoritmo ejercicio7
	//jeronimo medina
	//7. Hacer un algoritmo para sumar dos números, los cuales serán tecleados por el usuario. Mostrar el
	//resultado.
	//definicion
	definir numeroZ Como Real;
	definir numeroX Como Real;
	Definir suma Como Real;
	//inicio
	Escribir "digite un valor para z y otro para x";
	Leer numeroZ, numeroX;
	//Proceso 
	suma <- numeroZ + numeroX;
	//FinAlgoritmo
	Escribir " la suma de sus dos numeros digitados es: ",suma;
	
FinAlgoritmo
