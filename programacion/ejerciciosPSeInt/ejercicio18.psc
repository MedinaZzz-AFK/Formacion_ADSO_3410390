Proceso ejercicio18
	//jeronimo medina
	//18. Pedir un nºmero e indicar si es positivo o negativo.
	//definicion
	Definir num Como Real;
	
	//entrada
	Escribir " digite el numero ";
	leer num;
	//Proceso 
	si (num < 0) Entonces
		escribir " el numero es negativo ";
	SiNo
		escribir " el numero es positivo ";
	FinSi

	
FinProceso
